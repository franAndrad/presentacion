---
import Layout from '../layouts/Layout.astro';
import HeroCanvas from '../islands/HeroCanvas';
import { Shield, Database, Award, Globe, Cpu, Code2, Layers, Server, Binary, Menu, X } from 'lucide-react';

const techStack = [
	{ title: "FRONTEND ARCH", desc: "Interfaces reactivas de alto impacto con React, Astro y Tailwind.", tags: ["REACT", "ASTRO", "TS"], icon: Layers },
	{ title: "BACKEND CORE", desc: "Desarrollo de APIs robustas y microservicios con Node.js y Express.", tags: ["NODE.JS", "EXPRESS"], icon: Server },
	{ title: "DATABASE MGMT", desc: "Diseño y optimización de bases de datos relacionales y NoSQL.", tags: ["MONGODB", "SQL"], icon: Database },
	{ title: "INFRA & LAB", desc: "Despliegue en clusters Proxmox y orquestación con Docker.", tags: ["DOCKER", "PROXMOX"], icon: Cpu }
];

const projects = [
	{
		id: "01",
		title: "CUIDAR_APP",
		category: "HealthTech / Mobile First",
		desc: "Plataforma de gestión de pacientes y turnos médicos con monitoreo en tiempo real.",
		tags: ["REACT NATIVE", "NODE.JS", "MONGODB"],
		link: "#"
	},
	{
		id: "02",
		title: "DISTRO_CONTROL",
		category: "Infra / System Tools",
		desc: "Panel de control para la automatización de despliegues en contenedores Docker.",
		tags: ["REACT", "EXPRESS", "DOCKER_API"],
		link: "#"
	}
];

const hudIcons = [Code2, Binary, Database];
---

<Layout title="Francisco Andrade | Fullstack Engineer">
	<main class="relative min-h-screen bg-black overflow-x-hidden">
		<!-- Navigation (Mobile Friendly) -->
		<nav class="fixed top-0 w-full z-50 px-6 py-4 flex justify-between items-center mix-blend-difference">
			<div class="text-accent font-mono text-[10px] tracking-[0.4em] uppercase font-bold animate-fade-in">
				FA.sys // 2026
			</div>
			<div class="flex gap-4 md:gap-8 font-mono text-[9px] tracking-widest text-white/50 uppercase">
				<a href="https://github.com/franAndrad" target="_blank" class="hover:text-accent transition-colors">GitHub</a>
				<a href="https://linkedin.com/in/franandrad" target="_blank" class="hover:text-accent transition-colors">LinkedIn</a>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="min-h-screen relative flex flex-col items-center justify-center pt-20 pb-12 overflow-hidden">
			<HeroCanvas client:only="react" />
			
			<div class="z-10 w-full max-w-7xl px-6 md:px-12 flex flex-col lg:flex-row items-center lg:items-end justify-between select-none pointer-events-none opacity-0 animate-reveal">
				<div class="space-y-4 text-center lg:text-left">
					<div class="flex items-center justify-center lg:justify-start gap-2 text-accent/60 text-[10px] font-mono tracking-[0.5em] uppercase mb-2 overflow-hidden">
						<span class="inline-block animate-slide-up">01. Identity Core</span>
						<div class="hidden lg:block w-12 h-px bg-accent/30" />
					</div>
					<h1 class="text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-black tracking-tighter leading-[0.8] italic flex flex-col">
						<span class="text-white filter drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]">FRANCISCO</span>
						<span class="text-accent stroke-text-solid">ANDRADE</span>
					</h1>
					<p class="text-accent text-xs md:text-sm lg:text-base font-mono font-bold tracking-[0.3em] uppercase mt-8 animate-pulse-slow">
						FULLSTACK DEVELOPER @ UTN FRC
					</p>
				</div>
				
				<div class="flex flex-col items-center lg:items-end space-y-6 lg:space-y-8 mt-12 lg:mt-0 lg:pb-12 w-full lg:w-auto">
					<div class="space-y-1 text-center lg:text-right">
						<p class="text-[9px] text-accent/40 font-mono tracking-widest uppercase">Especialización</p>
						<p class="text-[11px] text-white/60 font-mono italic">DESARROLLO_MERN_STACK</p>
					</div>
					<div class="space-y-1 text-center lg:text-right">
						<p class="text-[9px] text-accent/40 font-mono tracking-widest uppercase">Localización</p>
						<p class="text-[11px] text-white/60 font-mono uppercase tracking-tighter">Córdoba, Argentina</p>
					</div>
				</div>
			</div>

			{/* Decorative HUD Elements - Simplified for Mobile */}
			<div class="absolute inset-0 pointer-events-none opacity-0 animate-fade-in delay-500">
				<div class="absolute top-20 left-6 lg:top-12 lg:left-12 border-l border-t border-accent/10 w-16 h-16 lg:w-32 lg:h-32" />
				<div class="absolute bottom-6 right-6 lg:bottom-12 lg:right-12 border-r border-b border-accent/10 w-16 h-16 lg:w-32 lg:h-32" />
				
				<div class="hidden md:flex absolute top-1/2 left-8 -translate-y-1/2 flex-col space-y-12">
					{hudIcons.map((Icon) => (
						<div class="text-accent/20 hover:text-accent/60 transition-colors pointer-events-auto cursor-crosshair">
							<Icon size={14} />
						</div>
					))}
				</div>
			</div>
			
			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 opacity-0 animate-bounce-slow delay-500 pointer-events-none">
				<span class="text-[8px] text-accent/40 font-mono tracking-[0.5em] uppercase text-center">Explorar Proyectos</span>
				<div class="w-px h-12 bg-gradient-to-b from-transparent via-accent to-transparent"></div>
			</div>
		</section>

		<!-- The Lab / Projects Section -->
		<section id="lab" class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 py-24 md:py-48 flex flex-col gap-12">
			<div class="flex flex-col md:flex-row justify-between items-end gap-8 border-b border-white/5 pb-12">
				<div class="space-y-4">
					<div class="text-accent text-xs font-mono tracking-[0.5em] uppercase">02. Selected Projects</div>
					<h2 class="text-4xl md:text-7xl font-black italic tracking-tighter uppercase leading-none">THE_LAB</h2>
				</div>
				<div class="max-w-md text-right">
					<p class="text-gray-500 text-xs font-mono leading-relaxed uppercase tracking-tighter">
						Experimentación y despliegue de soluciones escalables. <br/>
						<span class="text-accent/60">Sistemas críticos y arquitecturas modernas.</span>
					</p>
				</div>
			</div>

			<div class="grid md:grid-cols-2 gap-px bg-white/5 border border-white/5">
				{projects.map((project) => (
					<div class="group relative bg-black p-8 md:p-16 hover:bg-accent/[0.02] transition-colors duration-700">
						<div class="absolute top-8 right-8 text-accent/20 font-mono text-4xl font-black italic group-hover:text-accent/40 transition-colors italic">{project.id}</div>
						<div class="space-y-8">
							<div class="space-y-2">
								<p class="text-[9px] text-accent font-mono uppercase tracking-[0.3em]">{project.category}</p>
								<h3 class="text-3xl md:text-5xl font-black italic tracking-tighter text-white group-hover:translate-x-2 transition-transform duration-500 uppercase">{project.title}</h3>
							</div>
							<p class="text-gray-500 text-sm font-mono leading-relaxed max-w-sm">{project.desc}</p>
							<div class="flex flex-wrap gap-3">
								{project.tags.map(tag => (
									<span class="text-[9px] text-white/40 border border-white/10 px-3 py-1 font-mono uppercase tracking-widest">{tag}</span>
								))}
							</div>
							<a href={project.link} class="inline-flex items-center gap-4 text-accent text-[10px] font-mono tracking-[0.4em] uppercase group/link">
								<span class="group-hover/link:underline underline-offset-8">Ver Documentación</span>
								<div class="w-8 h-px bg-accent transform origin-left group-hover/link:scale-x-150 transition-transform" />
							</a>
						</div>
					</div>
				))}
			</div>

			<div class="mt-24 grid lg:grid-cols-12 gap-12 lg:gap-16">
				<div class="lg:col-span-4 space-y-8 lg:sticky lg:top-24 h-fit text-center lg:text-left flex flex-col items-center lg:items-start">
					<div class="space-y-4">
						<div class="text-accent text-xs font-mono tracking-[0.5em] uppercase">03. Stack & Lab</div>
						<h2 class="text-4xl md:text-5xl font-black italic tracking-tighter uppercase leading-none">CORE_SKILLS</h2>
						<div class="w-16 h-1 bg-accent shadow-[0_0_15px_#0087c8]" />
					</div>
					<p class="text-gray-400 text-sm leading-relaxed font-mono max-w-md">
						Enfoque en la creación de soluciones integrales. Desde la infraestructura en servidores propios hasta el despliegue de interfaces modernas y escalables.
					</p>
					<div class="pt-4 grid grid-cols-2 gap-4 w-full">
						<div class="border border-white/5 bg-white/[0.02] p-4">
							<p class="text-[8px] text-accent font-mono uppercase tracking-widest mb-1">Stack Preferido</p>
							<p class="text-[10px] md:text-sm font-black text-white italic tracking-tighter uppercase">MERN + Astro</p>
						</div>
						<div class="border border-white/5 bg-white/[0.02] p-4">
							<p class="text-[8px] text-accent font-mono uppercase tracking-widest mb-1">Metodología</p>
							<p class="text-[10px] md:text-sm font-black text-white italic tracking-tighter uppercase">Agile / Git</p>
						</div>
					</div>
				</div>

				<div class="lg:col-span-8 grid sm:grid-cols-2 gap-4 md:gap-6">
					{techStack.map((item) => {
						const ItemIcon = item.icon;
						return (
							<div class="group relative bg-white/[0.02] border border-white/5 p-6 md:p-10 rounded-sm hover:border-accent/40 transition-all duration-700 overflow-hidden">
								<div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-80 group-hover:text-accent transition-all duration-700">
									<ItemIcon size={24} strokeWidth={1.5} />
								</div>
								<div class="relative space-y-4 md:space-y-6">
									<h3 class="text-xl md:text-2xl font-black tracking-tight italic text-white group-hover:text-accent transition-colors uppercase">{item.title}</h3>
									<p class="text-gray-500 text-[11px] md:text-xs font-mono leading-relaxed">{item.desc}</p>
									<div class="flex flex-wrap gap-2 pt-2 md:pt-4">
										{item.tags.map(tag => (
											<span class="text-[8px] border border-accent/20 text-accent/60 px-2 md:px-3 py-1 font-mono tracking-widest uppercase">{tag}</span>
										))}
									</div>
								</div>
								<div class="absolute inset-0 bg-accent/[0.03] translate-y-full group-hover:translate-y-0 transition-transform duration-1000" />
							</div>
						);
					})}
				</div>
			</div>
		</section>

		<!-- Academic / Experience Section -->
		<section class="relative z-10 py-24 md:py-48 bg-white/[0.01] border-y border-white/5">
			<div class="max-w-7xl mx-auto px-6 md:px-12 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
				<div class="space-y-12 text-center lg:text-left flex flex-col items-center lg:items-start">
					<div class="space-y-4">
						<div class="text-accent text-xs font-mono tracking-[0.5em] uppercase">04. Formación</div>
						<h2 class="text-4xl md:text-6xl font-black italic tracking-tighter uppercase leading-none">LOG_ACADÉMICO</h2>
					</div>
					
					<div class="relative space-y-10 md:space-y-12 border-l border-accent/20 pl-8 text-left w-full max-w-md lg:max-w-none">
						<div class="relative group cursor-crosshair">
							<div class="absolute left-[-37px] top-2 w-2 h-2 bg-accent shadow-[0_0_10px_#0087c8]" />
							<p class="text-[9px] text-accent font-mono uppercase tracking-[0.3em] mb-1">Desde 2021 // ACTUALIDAD</p>
							<h4 class="text-xl md:text-2xl font-black italic text-white leading-tight uppercase">Ingeniería en Sistemas de Información</h4>
							<p class="text-accent/60 font-mono text-[10px] md:text-xs mt-1 uppercase">UTN FRC - Córdoba</p>
						</div>

						<div class="relative group cursor-crosshair">
							<div class="absolute left-[-37px] top-2 w-2 h-2 bg-white/40" />
							<p class="text-[9px] text-gray-500 font-mono uppercase tracking-[0.3em] mb-1">2022 (INTENSIVO 6 MESES)</p>
							<h4 class="text-xl md:text-2xl font-black italic text-white/90 leading-tight uppercase">Programador FullStack MERN</h4>
							<p class="text-gray-600 font-mono text-[10px] md:text-xs mt-1 uppercase italic">RollingCode School</p>
						</div>

						<div class="relative group cursor-crosshair">
							<div class="absolute left-[-37px] top-2 w-2 h-2 bg-white/20" />
							<p class="text-[9px] text-gray-600 font-mono uppercase tracking-[0.3em] mb-1">2020</p>
							<h4 class="text-xl md:text-2xl font-black italic text-white/70 leading-tight uppercase">Ingeniería Electrónica</h4>
							<p class="text-gray-600 font-mono text-[10px] md:text-xs mt-1 uppercase">UTN FRC - Córdoba</p>
						</div>

						<div class="relative group cursor-crosshair">
							<div class="absolute left-[-37px] top-2 w-2 h-2 bg-white/10" />
							<p class="text-[9px] text-gray-700 font-mono uppercase tracking-[0.3em] mb-1">2014 - 2019 (6 AÑOS)</p>
							<h4 class="text-xl md:text-2xl font-black italic text-white/60 leading-tight uppercase">Técnico Electrónico</h4>
							<p class="text-gray-700 font-mono text-[10px] md:text-xs mt-1 uppercase italic leading-tight">Escuela Técnica N1 Mtro. Humberto Samuel Luna<br/>Perico, Jujuy</p>
						</div>
					</div>
				</div>

				<div class="relative aspect-video group cursor-pointer perspective-1000 max-w-2xl w-full mx-auto lg:mx-0">
					<div class="absolute -inset-2 md:-inset-4 border border-accent/10 -z-10 group-hover:scale-105 transition-transform duration-700" />
					<div class="relative w-full h-full overflow-hidden border border-white/10 group-hover:border-accent/40 transition-colors">
						<img 
							src="/assets/certificate.png" 
							alt="Certificado RollingCode Fullstack" 
							class="object-cover w-full h-full filter grayscale contrast-125 group-hover:grayscale-0 group-hover:scale-110 transition-all duration-1000 opacity-40 group-hover:opacity-100" 
						/>
						<div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center p-6 md:p-12 text-center group-hover:opacity-0 transition-opacity duration-700">
							<Award className="text-accent mb-4 md:mb-6" size={48} strokeWidth={1} />
							<span class="text-[8px] md:text-[10px] text-accent font-mono uppercase tracking-[0.4em] md:tracking-[0.6em] mb-2 md:mb-4">Certificación de Desarrollo</span>
							<p class="text-base md:text-xl font-black tracking-tighter italic uppercase text-white">Fullstack MERN Stack</p>
							<div class="mt-4 md:mt-8 flex gap-4">
								<span class="w-6 md:w-8 h-px bg-accent/30" />
								<span class="text-[8px] md:text-[9px] text-accent/60 font-mono tracking-widest uppercase">ROLLING_CODE_SCHOOL</span>
								<span class="w-6 md:w-8 h-px bg-accent/30" />
							</div>
						</div>
						<div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-20 bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,white_2px,white_4px)] transition-opacity" />
					</div>
				</div>
			</div>
		</section>

		{/* Contact / Network HUD */}
		<footer class="relative z-10 py-16 md:py-24 px-6 border-t border-white/5">
			<div class="max-w-7xl mx-auto text-center space-y-8 md:space-y-12">
				<div class="space-y-4">
					<h2 class="text-3xl md:text-4xl font-black italic tracking-tighter uppercase leading-none">CONECTAR_CON_EL_NODO</h2>
					<p class="text-gray-500 font-mono text-[10px] md:text-xs tracking-wider">fran.eze.andrad@gmail.com</p>
				</div>
				<div class="flex flex-wrap justify-center gap-6 md:gap-12 font-mono text-[9px] md:text-[10px] tracking-widest text-accent/40 uppercase">
					<a href="https://github.com/franAndrad" target="_blank" class="hover:text-accent transition-colors underline-offset-4 hover:underline">Github</a>
					<a href="https://linkedin.com/in/franandrad" target="_blank" class="hover:text-accent transition-colors underline-offset-4 hover:underline">LinkedIn</a>
					<a href="mailto:fran.eze.andrad@gmail.com" class="hover:text-accent transition-colors underline-offset-4 hover:underline">Email</a>
				</div>
				<p class="pt-8 md:pt-12 text-[8px] text-gray-700 font-mono tracking-[0.4em] md:tracking-[0.5em] uppercase">Francisco Andrade &copy; 2026 // Identity Core v2.0</p>
			</div>
		</footer>
	</main>
</Layout>

<style is:global>
	@keyframes reveal {
		from { opacity: 0; transform: translateY(30px) skewY(1deg); filter: blur(10px); }
		to { opacity: 1; transform: translateY(0) skewY(0); filter: blur(0); }
	}
	@keyframes fade-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	@keyframes slide-up {
		from { transform: translateY(100%); }
		to { transform: translateY(0); }
	}
	@keyframes bounce-slow {
		0%, 100% { transform: translate(-50%, 0); opacity: 0.3; }
		50% { transform: translate(-50%, 15px); opacity: 0.8; }
	}
	@keyframes pulse-slow {
		0%, 100% { opacity: 0.6; }
		50% { opacity: 1; }
	}

	.animate-reveal { animation: reveal 1.2s cubic-bezier(0.2, 0, 0.2, 1) forwards; }
	.animate-fade-in { animation: fade-in 2s ease-out forwards; }
	.animate-slide-up { animation: slide-up 1s cubic-bezier(0.2, 0, 0.2, 1) forwards; }
	.animate-bounce-slow { animation: bounce-slow 3s infinite ease-in-out; }
	.animate-pulse-slow { animation: pulse-slow 4s infinite ease-in-out; }

	.delay-500 { animation-delay: 0.5s; }

	.stroke-text-solid {
		color: #0087c8;
		text-shadow: 0 0 30px rgba(0, 135, 200, 0.4);
	}
	
	.perspective-1000 {
		perspective: 1000px;
	}

	::-webkit-scrollbar {
		width: 4px;
	}
	::-webkit-scrollbar-track {
		background: #000;
	}
	::-webkit-scrollbar-thumb {
		background: #0087c8;
	}
</style>
