---
import Layout from '../layouts/Layout.astro';
import HeroCanvas from '../islands/HeroCanvas';
import { Shield, Database, Award, Globe, Cpu, Code2, Layers, Server, Binary } from 'lucide-react';

const techStack = [
	{ title: "FRONTEND ARCH", desc: "Interfaces reactivas de alto impacto con React, Astro y Tailwind.", tags: ["REACT", "ASTRO", "TS"], icon: Layers },
	{ title: "BACKEND CORE", desc: "Desarrollo de APIs robustas y microservicios con Node.js y Express.", tags: ["NODE.JS", "EXPRESS"], icon: Server },
	{ title: "DATABASE MGMT", desc: "Diseño y optimización de bases de datos relacionales y NoSQL.", tags: ["MONGODB", "SQL"], icon: Database },
	{ title: "INFRA & LAB", desc: "Despliegue en clusters Proxmox y orquestación con Docker.", tags: ["DOCKER", "PROXMOX"], icon: Cpu }
];

const hudIcons = [Code2, Binary, Database];
---

<Layout title="Francisco Andrade | Fullstack Engineer">
	<main class="relative min-h-screen bg-black overflow-hidden">
		<!-- Hero Section -->
		<section class="h-screen relative flex flex-col items-center justify-center overflow-hidden">
			<HeroCanvas client:only="react" />
			
			<div class="z-10 w-full max-w-7xl px-8 flex flex-col md:flex-row items-end justify-between select-none pointer-events-none opacity-0 animate-reveal">
				<div class="space-y-2 text-left">
					<div class="flex items-center gap-2 text-accent/60 text-xs font-mono tracking-[0.5em] uppercase mb-4 overflow-hidden">
						<span class="inline-block animate-slide-up">01. Identity Core</span>
						<div class="w-12 h-px bg-accent/30" />
					</div>
					<h1 class="text-7xl md:text-9xl font-black tracking-tighter leading-none italic flex flex-col">
						<span class="text-white filter drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]">FRANCISCO</span>
						<span class="text-accent stroke-text-solid">ANDRADE</span>
					</h1>
					<p class="text-accent text-sm md:text-base font-mono font-bold tracking-[0.3em] uppercase mt-6 animate-pulse-slow">
						FULLSTACK DEVELOPER @ UTN FRC
					</p>
				</div>
				
				<div class="hidden md:flex flex-col items-end space-y-8 pb-12">
					<div class="space-y-1 text-right">
						<p class="text-[10px] text-accent/40 font-mono tracking-widest uppercase">Especialización</p>
						<p class="text-xs text-white/60 font-mono italic">DESARROLLO_MERN_STACK</p>
					</div>
					<div class="space-y-1 text-right">
						<p class="text-[10px] text-accent/40 font-mono tracking-widest uppercase">Localización</p>
						<p class="text-xs text-white/60 font-mono uppercase tracking-tighter">Córdoba, Argentina</p>
					</div>
				</div>
			</div>

			<div class="absolute inset-0 pointer-events-none opacity-0 animate-fade-in delay-500">
				<div class="absolute top-12 left-12 border-l border-t border-accent/20 w-32 h-32" />
				<div class="absolute bottom-12 right-12 border-r border-b border-accent/20 w-32 h-32" />
				<div class="absolute top-1/2 left-8 -translate-y-1/2 space-y-12">
					{hudIcons.map((Icon) => (
						<div class="text-accent/20 hover:text-accent/60 transition-colors pointer-events-auto cursor-crosshair">
							<Icon size={14} />
						</div>
					))}
				</div>
			</div>
			
			<div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 opacity-0 animate-bounce-slow delay-500 pointer-events-none">
				<span class="text-[10px] text-accent/40 font-mono tracking-[0.5em] uppercase text-center">Explorar Proyectos</span>
				<div class="w-px h-16 bg-gradient-to-b from-transparent via-accent to-transparent"></div>
			</div>
		</section>

		<!-- The Lab / Projects Section -->
		<section class="relative z-10 max-w-7xl mx-auto px-8 py-48 grid lg:grid-cols-12 gap-16">
			<div class="lg:col-span-4 space-y-8 sticky top-24 h-fit">
				<div class="space-y-4">
					<div class="text-accent text-xs font-mono tracking-[0.5em] uppercase">02. Stack & Lab</div>
					<h2 class="text-5xl font-black italic tracking-tighter uppercase leading-none">CORE_SKILLS</h2>
					<div class="w-16 h-1 bg-accent shadow-[0_0_15px_#0087c8]" />
				</div>
				<p class="text-gray-400 text-sm leading-relaxed font-mono">
					Enfoque en la creación de soluciones integrales. Desde la infraestructura en servidores propios hasta el despliegue de interfaces modernas y escalables.
				</p>
				<div class="pt-8 grid grid-cols-2 gap-4 text-center">
					<div class="border border-white/5 bg-white/[0.02] p-4">
						<p class="text-[9px] text-accent font-mono uppercase tracking-widest mb-1">Stack Preferido</p>
						<p class="text-sm font-black text-white italic tracking-tighter uppercase">MERN + Astro</p>
					</div>
					<div class="border border-white/5 bg-white/[0.02] p-4">
						<p class="text-[9px] text-accent font-mono uppercase tracking-widest mb-1">Metodología</p>
						<p class="text-sm font-black text-white italic tracking-tighter uppercase">Agile / Git</p>
					</div>
				</div>
			</div>

			<div class="lg:col-span-8 grid md:grid-cols-2 gap-6">
				{techStack.map((item) => {
					const ItemIcon = item.icon;
					return (
						<div class="group relative bg-white/[0.02] border border-white/5 p-10 rounded-sm hover:border-accent/40 transition-all duration-700 overflow-hidden">
							<div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-80 group-hover:text-accent transition-all duration-700">
								<ItemIcon size={24} strokeWidth={1.5} />
							</div>
							<div class="relative space-y-6">
								<h3 class="text-2xl font-black tracking-tight italic text-white group-hover:text-accent transition-colors uppercase">{item.title}</h3>
								<p class="text-gray-500 text-xs font-mono leading-relaxed">{item.desc}</p>
								<div class="flex flex-wrap gap-2 pt-4">
									{item.tags.map(tag => (
										<span class="text-[9px] border border-accent/20 text-accent/60 px-3 py-1 font-mono tracking-widest uppercase">{tag}</span>
									))}
								</div>
							</div>
							<div class="absolute inset-0 bg-accent/[0.03] translate-y-full group-hover:translate-y-0 transition-transform duration-1000" />
						</div>
					);
				})}
			</div>
		</section>

		<!-- Academic / Experience Section -->
		<section class="relative z-10 py-48 bg-white/[0.01] border-y border-white/5">
			<div class="max-w-7xl mx-auto px-8 grid lg:grid-cols-2 gap-24 items-center">
				<div class="space-y-12">
					<div class="space-y-4">
						<div class="text-accent text-xs font-mono tracking-[0.5em] uppercase">03. Formación</div>
						<h2 class="text-6xl font-black italic tracking-tighter uppercase leading-none">LOG_ACADÉMICO</h2>
					</div>
					
					<div class="relative space-y-12 border-l border-accent/20 pl-8">
						<div class="relative group cursor-crosshair">
							<div class="absolute left-[-37px] top-2 w-2 h-2 bg-accent shadow-[0_0_10px_#0087c8]" />
							<p class="text-[10px] text-accent font-mono uppercase tracking-[0.3em] mb-1">Desde 2023</p>
							<h4 class="text-2xl font-black italic text-white leading-tight uppercase">Ingeniería en Sistemas de Información</h4>
							<p class="text-accent/60 font-mono text-xs mt-1 uppercase">UTN FRC</p>
						</div>
						
						<div class="relative group cursor-crosshair">
							<div class="absolute left-[-37px] top-2 w-2 h-2 bg-white/20" />
							<p class="text-[10px] text-gray-500 font-mono uppercase tracking-[0.3em] mb-1">2022</p>
							<h4 class="text-2xl font-black italic text-white/80 leading-tight uppercase">Programador FullStack MERN</h4>
							<p class="text-gray-600 font-mono text-xs mt-1 uppercase italic">Certificación RollingCode School</p>
						</div>
					</div>
				</div>

				<div class="relative aspect-video group cursor-pointer perspective-1000">
					<div class="absolute -inset-4 border border-accent/10 -z-10 group-hover:scale-105 transition-transform duration-700" />
					<div class="relative w-full h-full overflow-hidden border border-white/10 group-hover:border-accent/40 transition-colors">
						<img 
							src="/assets/certificate.png" 
							alt="Certificado RollingCode Fullstack" 
							class="object-cover w-full h-full filter grayscale contrast-125 group-hover:grayscale-0 group-hover:scale-110 transition-all duration-1000 opacity-40 group-hover:opacity-100" 
						/>
						<div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center p-12 text-center group-hover:opacity-0 transition-opacity duration-700">
							<Award className="text-accent mb-6" size={48} strokeWidth={1} />
							<span class="text-[10px] text-accent font-mono uppercase tracking-[0.6em] mb-4">Diploma de Ingeniería de Software</span>
							<p class="text-xl font-black tracking-tighter italic uppercase text-white">Fullstack Engineering MERN</p>
							<div class="mt-8 flex gap-4">
								<span class="w-8 h-px bg-accent/30" />
								<span class="text-[9px] text-accent/60 font-mono tracking-widest uppercase">ROLLING_CODE_SCHOOL</span>
								<span class="w-8 h-px bg-accent/30" />
							</div>
						</div>
						<div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-20 bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,white_2px,white_4px)] transition-opacity" />
					</div>
				</div>
			</div>
		</section>

		{/* Contact / Network HUD */}
		<footer class="relative z-10 py-24 px-8 border-t border-white/5">
			<div class="max-w-7xl mx-auto text-center space-y-12">
				<div class="space-y-4">
					<h2 class="text-4xl font-black italic tracking-tighter uppercase leading-none">CONECTAR_CON_EL_NODO</h2>
					<p class="text-gray-500 font-mono text-xs">fran.eze.andrad@gmail.com</p>
				</div>
				<div class="flex justify-center gap-12 font-mono text-[10px] tracking-widest text-accent/40 uppercase">
					<a href="https://github.com/franAndrad" target="_blank" class="hover:text-accent transition-colors underline-offset-4 hover:underline">Github</a>
					<a href="https://linkedin.com/in/franandrad" target="_blank" class="hover:text-accent transition-colors underline-offset-4 hover:underline">LinkedIn</a>
					<a href="mailto:fran.eze.andrad@gmail.com" class="hover:text-accent transition-colors underline-offset-4 hover:underline">Email</a>
				</div>
				<p class="pt-12 text-[9px] text-gray-700 font-mono tracking-[0.5em] uppercase">Francisco Andrade &copy; 2026 // Identity Core v2.0</p>
			</div>
		</footer>
	</main>
</Layout>

<style is:global>
	@keyframes reveal {
		from { opacity: 0; transform: translateY(40px) skewY(2deg); filter: blur(10px); }
		to { opacity: 1; transform: translateY(0) skewY(0); filter: blur(0); }
	}
	@keyframes fade-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	@keyframes slide-up {
		from { transform: translateY(100%); }
		to { transform: translateY(0); }
	}
	@keyframes bounce-slow {
		0%, 100% { transform: translate(-50%, 0); opacity: 0.3; }
		50% { transform: translate(-50%, 15px); opacity: 0.8; }
	}
	@keyframes pulse-slow {
		0%, 100% { opacity: 0.6; }
		50% { opacity: 1; }
	}

	.animate-reveal { animation: reveal 1.2s cubic-bezier(0.2, 0, 0.2, 1) forwards; }
	.animate-fade-in { animation: fade-in 2s ease-out forwards; }
	.animate-slide-up { animation: slide-up 1s cubic-bezier(0.2, 0, 0.2, 1) forwards; }
	.animate-bounce-slow { animation: bounce-slow 3s infinite ease-in-out; }
	.animate-pulse-slow { animation: pulse-slow 4s infinite ease-in-out; }

	.delay-500 { animation-delay: 0.5s; }

	.stroke-text-solid {
		color: #0087c8;
		text-shadow: 0 0 30px rgba(0, 135, 200, 0.4);
	}
	
	.perspective-1000 {
		perspective: 1000px;
	}

	::-webkit-scrollbar {
		width: 4px;
	}
	::-webkit-scrollbar-track {
		background: #000;
	}
	::-webkit-scrollbar-thumb {
		background: #0087c8;
	}
</style>
